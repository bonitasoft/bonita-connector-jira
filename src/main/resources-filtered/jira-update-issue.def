<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">

  <id>${jira-update-issue.def.id}</id>
  <version>${jira-update-issue.def.version}</version>
  <icon>jira.png</icon>
  <category icon="jira.png" id="JIRA"/>

  <input name="atlassianDomain" type="java.lang.String" mandatory="true"/>
  <input name="authMode" type="java.lang.String" mandatory="false" defaultValue="BASIC"/>
  <input name="userEmail" type="java.lang.String" mandatory="false"/>
  <input name="apiToken" type="java.lang.String" mandatory="false"/>
  <input name="oauthClientId" type="java.lang.String" mandatory="false"/>
  <input name="oauthClientSecret" type="java.lang.String" mandatory="false"/>
  <input name="oauthRefreshToken" type="java.lang.String" mandatory="false"/>
  <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
  <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>
  <input name="issueKey" type="java.lang.String" mandatory="true"/>
  <input name="notifyUsers" type="java.lang.Boolean" mandatory="false" defaultValue="true"/>
  <input name="summary" type="java.lang.String" mandatory="false"/>
  <input name="description" type="java.lang.String" mandatory="false"/>
  <input name="priority" type="java.lang.String" mandatory="false"/>
  <input name="assigneeAccountId" type="java.lang.String" mandatory="false"/>
  <input name="labels" type="java.lang.String" mandatory="false"/>
  <input name="addLabels" type="java.lang.String" mandatory="false"/>
  <input name="removeLabels" type="java.lang.String" mandatory="false"/>
  <input name="dueDate" type="java.lang.String" mandatory="false"/>
  <input name="customFields" type="java.lang.String" mandatory="false"/>

  <output name="issueKey" type="java.lang.String"/>
  <output name="success" type="java.lang.Boolean"/>
  <output name="errorMessage" type="java.lang.String"/>

  <page id="connectionPage">
    <widget xsi:type="definition:Text" id="atlassianDomainWidget" inputName="atlassianDomain"/>
    <widget xsi:type="definition:Select" id="authModeWidget" inputName="authMode"><items>BASIC</items><items>OAUTH2</items></widget>
    <widget xsi:type="definition:Text" id="userEmailWidget" inputName="userEmail"/>
    <widget xsi:type="definition:Password" id="apiTokenWidget" inputName="apiToken"/>
    <widget xsi:type="definition:Text" id="oauthClientIdWidget" inputName="oauthClientId"/>
    <widget xsi:type="definition:Password" id="oauthClientSecretWidget" inputName="oauthClientSecret"/>
    <widget xsi:type="definition:Password" id="oauthRefreshTokenWidget" inputName="oauthRefreshToken"/>
    <widget xsi:type="definition:Text" id="connectTimeoutWidget" inputName="connectTimeout"/>
    <widget xsi:type="definition:Text" id="readTimeoutWidget" inputName="readTimeout"/>
  </page>
  <page id="operationPage">
    <widget xsi:type="definition:Text" id="issueKeyWidget" inputName="issueKey"/>
    <widget xsi:type="definition:Checkbox" id="notifyUsersWidget" inputName="notifyUsers"/>
  </page>
  <page id="configurationPage">
    <widget xsi:type="definition:Text" id="summaryWidget" inputName="summary"/>
    <widget xsi:type="definition:TextArea" id="descriptionWidget" inputName="description"/>
    <widget xsi:type="definition:Select" id="priorityWidget" inputName="priority"><items>Highest</items><items>High</items><items>Medium</items><items>Low</items><items>Lowest</items></widget>
    <widget xsi:type="definition:Text" id="assigneeAccountIdWidget" inputName="assigneeAccountId"/>
    <widget xsi:type="definition:Text" id="labelsWidget" inputName="labels"/>
    <widget xsi:type="definition:Text" id="addLabelsWidget" inputName="addLabels"/>
    <widget xsi:type="definition:Text" id="removeLabelsWidget" inputName="removeLabels"/>
    <widget xsi:type="definition:Text" id="dueDateWidget" inputName="dueDate"/>
  </page>
  <page id="advancedPage">
    <widget xsi:type="definition:TextArea" id="customFieldsWidget" inputName="customFields"/>
  </page>
</definition:ConnectorDefinition>
