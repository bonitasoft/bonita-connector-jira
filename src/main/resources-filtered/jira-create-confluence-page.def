<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">
  <id>${jira-create-confluence-page.def.id}</id>
  <version>${jira-create-confluence-page.def.version}</version>
  <icon>jira.png</icon>
  <category icon="jira.png" id="JIRA"/>
  <input name="atlassianDomain" type="java.lang.String" mandatory="true"/>
  <input name="authMode" type="java.lang.String" mandatory="false" defaultValue="BASIC"/>
  <input name="userEmail" type="java.lang.String" mandatory="false"/>
  <input name="apiToken" type="java.lang.String" mandatory="false"/>
  <input name="oauthClientId" type="java.lang.String" mandatory="false"/>
  <input name="oauthClientSecret" type="java.lang.String" mandatory="false"/>
  <input name="oauthRefreshToken" type="java.lang.String" mandatory="false"/>
  <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
  <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>
  <input name="spaceId" type="java.lang.String" mandatory="true"/>
  <input name="parentPageId" type="java.lang.String" mandatory="false"/>
  <input name="pageTitle" type="java.lang.String" mandatory="true"/>
  <input name="pageContent" type="java.lang.String" mandatory="true"/>
  <input name="contentFormat" type="java.lang.String" mandatory="false" defaultValue="storage"/>
  <input name="status" type="java.lang.String" mandatory="false" defaultValue="current"/>
  <input name="labels" type="java.lang.String" mandatory="false"/>
  <output name="pageId" type="java.lang.String"/>
  <output name="pageTitle" type="java.lang.String"/>
  <output name="pageUrl" type="java.lang.String"/>
  <output name="pageVersion" type="java.lang.Integer"/>
  <output name="success" type="java.lang.Boolean"/>
  <output name="errorMessage" type="java.lang.String"/>
  <page id="connectionPage">
    <widget xsi:type="definition:Text" id="atlassianDomainWidget" inputName="atlassianDomain"/>
    <widget xsi:type="definition:Select" id="authModeWidget" inputName="authMode"><items>BASIC</items><items>OAUTH2</items></widget>
    <widget xsi:type="definition:Text" id="userEmailWidget" inputName="userEmail"/>
    <widget xsi:type="definition:Password" id="apiTokenWidget" inputName="apiToken"/>
    <widget xsi:type="definition:Text" id="oauthClientIdWidget" inputName="oauthClientId"/>
    <widget xsi:type="definition:Password" id="oauthClientSecretWidget" inputName="oauthClientSecret"/>
    <widget xsi:type="definition:Password" id="oauthRefreshTokenWidget" inputName="oauthRefreshToken"/>
    <widget xsi:type="definition:Text" id="connectTimeoutWidget" inputName="connectTimeout"/>
    <widget xsi:type="definition:Text" id="readTimeoutWidget" inputName="readTimeout"/>
  </page>
  <page id="configurationPage">
    <widget xsi:type="definition:Text" id="spaceIdWidget" inputName="spaceId"/>
    <widget xsi:type="definition:Text" id="parentPageIdWidget" inputName="parentPageId"/>
  </page>
  <page id="operationPage">
    <widget xsi:type="definition:Text" id="pageTitleWidget" inputName="pageTitle"/>
    <widget xsi:type="definition:TextArea" id="pageContentWidget" inputName="pageContent"/>
    <widget xsi:type="definition:Select" id="contentFormatWidget" inputName="contentFormat"><items>storage</items><items>atlas_doc_format</items><items>wiki</items></widget>
    <widget xsi:type="definition:Select" id="statusWidget" inputName="status"><items>current</items><items>draft</items></widget>
    <widget xsi:type="definition:Text" id="labelsWidget" inputName="labels"/>
  </page>
</definition:ConnectorDefinition>
